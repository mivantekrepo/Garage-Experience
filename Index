/* ── Accessibility-first design tokens ── */
.a11y-page {
  background: #FAFAFA;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.a11y-topbar {
  background: white;
  border-bottom: 2px solid #E8E8ED;
  padding: 20px 32px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.a11y-bc {
  font-size: 13px;
  color: #6B7280;
  font-weight: 600;
  margin-bottom: 4px;
}
.a11y-bc a {
  color: var(--teal);
  text-decoration: none;
  cursor: pointer;
}
.a11y-bc a:hover { text-decoration: underline; }
.a11y-page-title {
  font-family: var(--font-head);
  font-size: 26px;
  font-weight: 900;
  color: var(--navy);
  margin: 0;
}
.a11y-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 32px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.a11y-scroll > .a11y-content {
  width: 100%;
}
.a11y-scroll::-webkit-scrollbar { width: 6px; }
.a11y-scroll::-webkit-scrollbar-thumb { background: #D1D5DB; border-radius: 3px; }

/* Section label */
.a11y-section-label {
  font-size: 11px;
  font-weight: 800;
  color: #9CA3AF;
  text-transform: uppercase;
  letter-spacing: .1em;
  margin-bottom: 14px;
  margin-top: 32px;
}
.a11y-section-label:first-child { margin-top: 0; }

/* Big pill option rows — the core interaction pattern */
.a11y-pill-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 24px;
}
.a11y-pill {
  display: flex;
  align-items: center;
  gap: 16px;
  width: 100%;
  padding: 20px 24px;
  background: white;
  border: 2px solid #E5E7EB;
  border-radius: 18px;
  cursor: pointer;
  text-align: left;
  transition: all 0.15s;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  font-family: var(--font-head);
  font-size: 16px;
  font-weight: 700;
  color: #111827;
  min-height: 72px;
}
.a11y-pill:hover {
  border-color: var(--teal);
  box-shadow: 0 4px 16px rgba(53,100,126,0.15);
  transform: translateY(-1px);
}
.a11y-pill:focus-visible {
  outline: 3px solid var(--teal);
  outline-offset: 2px;
}
.a11y-pill.selected {
  border-color: var(--olive);
  background: var(--olive-faint);
  color: var(--navy);
  box-shadow: 0 2px 0 var(--olive);
}
.a11y-pill-icon {
  font-size: 26px;
  flex-shrink: 0;
  width: 40px;
  text-align: center;
}
.a11y-pill-body { flex: 1; }
.a11y-pill-title { font-size: 16px; font-weight: 800; color: #111827; margin-bottom: 2px; }
.a11y-pill-sub { font-size: 13px; color: #6B7280; font-weight: 500; line-height: 1.5; }
.a11y-pill.selected .a11y-pill-title { color: var(--navy); }
.a11y-pill-check {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--olive); color: white;
  display: none; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 900; flex-shrink: 0;
}
.a11y-pill.selected .a11y-pill-check { display: flex; }

/* Status badges */
.a11y-badge {
  font-size: 11px; font-weight: 800; padding: 4px 12px;
  border-radius: 100px; flex-shrink: 0;
}
.a11y-badge-green  { background: #DCFCE7; color: #15803D; }
.a11y-badge-blue   { background: #DBEAFE; color: #1D4ED8; }
.a11y-badge-orange { background: #FEF3C7; color: #92400E; }
.a11y-badge-gray   { background: #F3F4F6; color: #6B7280; }

/* Content cards */
.a11y-card {
  background: white;
  border: 2px solid #E5E7EB;
  border-radius: 18px;
  padding: 24px 28px;
  margin-bottom: 14px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.a11y-card-title {
  font-family: var(--font-head);
  font-size: 17px;
  font-weight: 800;
  color: var(--navy);
  margin-bottom: 6px;
}
.a11y-card-body { font-size: 14px; color: #6B7280; line-height: 1.65; }

/* Primary CTA button */
.a11y-cta {
  display: block;
  width: 100%;
  max-width: 480px;
  margin: 8px auto 0;
  padding: 18px 24px;
  background: var(--navy);
  color: white;
  border: none;
  border-radius: 100px;
  font-family: var(--font-head);
  font-size: 17px;
  font-weight: 800;
  cursor: pointer;
  text-align: center;
  transition: all 0.15s;
  min-height: 60px;
  box-shadow: 0 4px 0 #001050;
}
.a11y-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 0 #001050; }
.a11y-cta:active { transform: translateY(2px); box-shadow: 0 2px 0 #001050; }
.a11y-cta:focus-visible { outline: 3px solid var(--teal); outline-offset: 3px; }
.a11y-cta.olive {
  background: var(--olive); box-shadow: 0 4px 0 var(--olive-dark);
}
.a11y-cta.olive:hover { box-shadow: 0 6px 0 var(--olive-dark); }
.a11y-cta.outline {
  background: white; color: var(--navy);
  border: 2.5px solid var(--navy); box-shadow: none;
}
.a11y-cta.outline:hover { background: var(--navy-faint); box-shadow: none; }

/* Two-col grid for desktop */
.a11y-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.a11y-grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
@media (max-width: 700px) {
  .a11y-grid-2, .a11y-grid-3 { grid-template-columns: 1fr; }
}

/* Content constraint */
.a11y-content { max-width: 680px; }

/* Guide bar */
.a11y-guide-bar {
  background: var(--navy);
  border-radius: 16px;
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 28px;
}
.a11y-guide-av {
  width: 40px; height: 40px; border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; flex-shrink: 0;
}
.a11y-guide-text { font-size: 14px; color: rgba(255,255,255,0.9); line-height: 1.55; }
.a11y-guide-name { font-size: 11px; font-weight: 800; color: rgba(255,255,255,0.45); margin-bottom: 3px; }

/* Input */
.a11y-input {
  width: 100%; height: 56px; padding: 0 18px;
  border: 2.5px solid #E5E7EB; border-radius: 14px;
  font-family: var(--font-head); font-size: 15px; outline: none;
  transition: border-color 0.15s; background: white; color: #111827;
}
.a11y-input:focus { border-color: var(--teal); }
.a11y-input::placeholder { color: #9CA3AF; }

/* Unlock banner */
.a11y-unlock-bar {
  background: linear-gradient(135deg, var(--olive), var(--olive-dark));
  border-radius: 16px;
  padding: 20px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 28px;
}
.a11y-unlock-text h3 { font-family:var(--font-head); font-size:16px; font-weight:800; color:white; margin-bottom:4px; }
.a11y-unlock-text p  { font-size:13px; color:rgba(255,255,255,0.8); line-height:1.5; }
.a11y-unlock-btn {
  background: white; color: var(--olive); border: none;
  border-radius: 100px; padding: 12px 22px;
  font-family: var(--font-head); font-size: 14px; font-weight: 800;
  cursor: pointer; white-space: nowrap; flex-shrink: 0; min-height: 48px;
  transition: all 0.15s;
}
.a11y-unlock-btn:hover { background: var(--olive-faint); }
.a11y-unlock-btn:focus-visible { outline: 3px solid white; outline-offset: 2px; }




