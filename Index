.dest:hover{transform:translateY(-4px) scale(1.04);box-shadow:0 8px 24px rgba(0,25,112,0.2);border-color:var(--teal);}.dest.sel{border-color:var(--olive);box-shadow:0 0 0 3px rgba(122,133,59,0.28),0 8px 24px rgba(0,25,112,0.2);transform:translateY(-4px) scale(1.04);}
.dest-thumb{width:100%;height:72px;overflow:hidden;}.dest-body{padding:8px 9px 9px;}.dest-name{font-family:var(--font-head);font-size:12px;font-weight:800;color:var(--navy);display:block;margin-bottom:2px;}.dest-sub{font-size:12px;color:var(--gray-700);display:block;}
.dest-alert{display:block;width:fit-content;background:#FEE2E2;color:#B91C1C;font-family:var(--font-head);font-size:9px;font-weight:800;border-radius:100px;padding:2px 8px;margin-top:4px;}
.player-car{position:absolute;z-index:6;filter:drop-shadow(0 4px 10px rgba(0,0,0,0.45));left:50%;top:50%;transform:translate(-50%,-50%);}
.nav-bub{position:absolute;z-index:10;background:var(--white);border-radius:var(--r-lg);padding:13px 16px;max-width:220px;box-shadow:var(--shadow-md);top:16px;left:50%;transform:translateX(-50%);border:1px solid var(--teal-mid);}
.nav-bub::after{content:'';position:absolute;bottom:-8px;left:20px;border-left:8px solid transparent;border-right:8px solid transparent;border-top:8px solid var(--white);}
.nb-hd{display:flex;align-items:center;gap:8px;margin-bottom:6px;}.nb-av{font-size:22px;line-height:1;}.nb-nm{font-family:var(--font-head);font-size:12px;font-weight:800;color:var(--teal);}.nb-txt{font-size:14px;color:var(--gray-700);line-height:1.7;}
.zl{font-family:var(--font-head);font-size:10px;font-weight:800;fill:rgba(53,100,126,0.8);}
#toast{position:fixed;bottom:24px;right:24px;background:var(--navy);color:var(--white);border:1px solid rgba(255,255,255,0.1);border-radius:var(--r-md);padding:13px 20px;font-family:var(--font-head);font-size:13px;font-weight:700;box-shadow:var(--shadow-lg);z-index:9999;opacity:0;transform:translateY(8px);pointer-events:none;transition:opacity .2s,transform .2s;}#toast.on{opacity:1;transform:translateY(0);}

/* === STICKER GARAGE SCOPED === */
#s-garage-inner .header {
    display: flex; align-items: center; gap: 12px; margin-bottom: 18px;
  }
#s-garage-inner .logo-pin {
    width: 36px; height: 36px; background: var(--navy);
    border-radius: 50% 50% 50% 0; transform: rotate(-45deg);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
#s-garage-inner .logo-pin span { transform: rotate(45deg); font-size: 17px; }
#s-garage-inner .header-text h1 { font-family:'Poppins', sans-serif; font-size: 1.5rem; color: var(--text); letter-spacing: 1px; line-height: 1; }
#s-garage-inner .header-text p { color: var(--muted); font-size: 0.78rem; margin-top: 2px; }
#s-garage-inner .car-picker {
    display: flex; gap: 12px; margin-bottom: 16px; width: 100%; max-width: 1080px;
  }
#s-garage-inner .car-option {
    flex: 1; cursor: pointer; border-radius: 14px; overflow: hidden;
    border: 3px solid var(--border); transition: all 0.2s;
    position: relative; aspect-ratio: 16/7; background: #0a0f1e;
  }
#s-garage-inner .car-option img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.3s ease;
  }
#s-garage-inner .car-option:hover { border-color: var(--teal); }
#s-garage-inner .car-option:hover img { transform: scale(1.04); }
#s-garage-inner .car-option.active { border-color: var(--olive); box-shadow: 0 0 0 2px var(--olive), 0 8px 24px rgba(122,133,59,0.3); }
#s-garage-inner .car-option .car-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 8px 12px;
    background: linear-gradient(to top, rgba(6,13,31,0.92) 0%, transparent 100%);
    font-size: 0.78rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 1px; color: var(--text);
    display: flex; align-items: center; justify-content: space-between;
  }
#s-garage-inner .car-option.active .car-label::after {
    content: "✓ Selected";
    font-size: 0.7rem; color: var(--olive); font-weight: 700;
  }
#s-garage-inner .car-option:not(.active) .car-label::after {
    content: "Tap to select";
    font-size: 0.7rem; color: var(--muted);
  }
#s-garage-inner .workspace { display: flex; gap: 14px; width: 100%; max-width: 1080px; align-items: flex-start; }
#s-garage-inner .stage-wrap {
    flex: 1; background: var(--surf); border-radius: 20px;
    padding: 16px; border: 1px solid var(--border);
  }
#s-garage-inner .view-strip {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;
  }
#s-garage-inner .spin-btn {
    width: 42px; height: 42px; border-radius: 50%;
    border: 2px solid var(--border); background: var(--surf2);
    color: var(--text); font-size: 1.3rem; cursor: pointer;
    transition: all 0.15s; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
#s-garage-inner .spin-btn:hover { background: var(--teal); border-color: var(--teal); transform: scale(1.08); }
#s-garage-inner .view-center { display: flex; flex-direction: column; align-items: center; gap: 5px; }
#s-garage-inner .side-pills { display: flex; gap: 6px; }
#s-garage-inner .side-pill {
    padding: 4px 14px; border-radius: 20px; font-size: 0.72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.8px; cursor: pointer;
    border: 1.5px solid var(--border); background: var(--surf2); color: var(--muted);
    transition: all 0.15s;
  }
#s-garage-inner .side-pill.active { background: var(--olive); border-color: var(--olive); color: #fff; }
#s-garage-inner .view-label { color: var(--muted); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
#s-garage-inner .canvas-outer {
    position: relative; width: 100%; border-radius: 14px;
    overflow: hidden; aspect-ratio: 16/9;
    background: radial-gradient(ellipse at 50% 80%, #0d1e3a 0%, #060d1f 100%);
  }
#s-garage-inner #car-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; opacity: 1;
    transition: opacity 0.22s ease, transform 0.28s cubic-bezier(0.4,0,0.2,1);
  }
#s-garage-inner #car-img.flip-out { opacity: 0; transform: scaleX(0.88); }
#s-garage-inner .canvas-outer::after {
    content: ""; position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(to top, rgba(4,8,20,0.5) 0%, transparent 55%);
    pointer-events: none;
  }
#s-garage-inner #sticker-layer { position: absolute; inset: 0; z-index: 2; pointer-events: none; }
#s-garage-inner .bottom-bar {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 12px; flex-wrap: wrap; gap: 8px;
  }
#s-garage-inner .bar-btns { display: flex; gap: 8px; flex-wrap: wrap; }
#s-garage-inner .btn {
    padding: 7px 14px; border-radius: 10px; border: 1px solid var(--border);
    background: var(--surf2); color: var(--text);
    font-family:'Inter',sans-serif; font-weight: 700; font-size: 0.8rem;
    cursor: pointer; transition: all 0.15s;
  }
#s-garage-inner .btn:hover { background: var(--teal); border-color: var(--teal); }
#s-garage-inner .btn.danger:hover { background: #c0392b; border-color: #c0392b; }
#s-garage-inner .hint { color: var(--muted); font-size: 0.72rem; line-height: 1.5; }
#s-garage-inner .sticker-obj {
    position: absolute; cursor: grab; touch-action: none;
    transform-origin: center center; pointer-events: all;
    filter: drop-shadow(1px 2px 8px rgba(0,0,0,0.75));
  }
#s-garage-inner .sticker-obj:hover { filter: drop-shadow(0 0 10px rgba(122,133,59,0.85)); }
#s-garage-inner .sticker-obj.selected { outline: 2px dashed var(--olive); outline-offset: 4px; filter: drop-shadow(0 0 14px rgba(122,133,59,1)); }
#s-garage-inner .sticker-obj.dragging { cursor: grabbing; opacity: 0.82; }
#s-garage-inner .s-emoji { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; pointer-events: none; line-height: 1; }
#s-garage-inner .h-rotate {
    position: absolute; top: -26px; left: 50%; transform: translateX(-50%);
    width: 20px; height: 20px; background: #ffd166; border-radius: 50%;
    cursor: grab; border: 2px solid #fff; display: none;
    align-items: center; justify-content: center; font-size: 11px; z-index: 20; pointer-events: all;
  }
#s-garage-inner .h-delete {
    position: absolute; top: -10px; right: -10px;
    width: 20px; height: 20px; background: #e74c3c; border-radius: 50%;
    cursor: pointer; border: 2px solid #fff; display: none;
    align-items: center; justify-content: center; font-size: 13px; color: #fff;
    font-weight: bold; z-index: 20; pointer-events: all; line-height: 1;
  }
#s-garage-inner .h-resize {
    position: absolute; bottom: -10px; right: -10px;
    width: 20px; height: 20px; background: var(--olive); border-radius: 4px;
    cursor: nwse-resize; border: 2px solid #fff; display: none;
    align-items: center; justify-content: center; font-size: 10px; color: #fff;
    z-index: 20; pointer-events: all;
  }
#s-garage-inner .panel {
    width: 206px; flex-shrink: 0; background: var(--surf);
    border-radius: 20px; padding: 16px; border: 1px solid var(--border);
  }
#s-garage-inner .panel-title { font-family:'Poppins', sans-serif; font-size: 1.05rem; color: var(--text); margin-bottom: 10px; letter-spacing: 1px; }
#s-garage-inner .sec-label { font-size: 0.67rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin: 10px 0 5px; }
#s-garage-inner .sticker-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 5px; }
#s-garage-inner .thumb {
    aspect-ratio: 1; background: var(--surf2); border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; cursor: pointer; border: 2px solid transparent; transition: all 0.13s;
  }
#s-garage-inner .thumb:hover { border-color: var(--olive); transform: scale(1.12); }
#s-garage-inner .ctrl-section { margin-top: 12px; border-top: 1px solid var(--border); padding-top: 12px; }
#s-garage-inner #no-sel { color: var(--muted); font-size: 0.76rem; font-style: italic; }
#s-garage-inner #sel-ctrls { display: none; }
#s-garage-inner .ctrl-row { display: flex; justify-content: space-between; font-size: 0.76rem; color: var(--muted); font-weight: 700; margin-bottom: 4px; }
#s-garage-inner .ctrl-val { color: var(--olive); font-family: monospace; }
#s-garage-inner input[type=range] { width: 100%; accent-color: var(--teal); margin-bottom: 8px; }
#s-garage-inner .mini-row { display: flex; gap: 5px; margin-bottom: 6px; }
#s-garage-inner .mini-btn {
    flex: 1; padding: 5px 0; text-align: center; border-radius: 7px;
    border: 1px solid var(--border); background: var(--surf2); color: var(--text);
    font-family:'Inter',sans-serif; font-weight: 700; font-size: 0.72rem; cursor: pointer; transition: all 0.13s;
  }
#s-garage-inner .mini-btn:hover { background: var(--teal); border-color: var(--teal); }
#s-garage-inner .gar-workspace { display: flex; gap: 14px; width: 100%; align-items: flex-start; }
#s-garage .app-scroll { background: #f4f6f9; }
#s-garage-inner { font-family:'Inter',sans-serif; color: #e8eef8; }


/* ── Garage tabs ── */
.gar-tabs{flex-shrink:0;display:flex;padding:0 22px;background:var(--white);border-bottom:1px solid var(--gray-200);}
.g-tab{padding:14px 20px;min-height:48px;font-family:var(--font-head);font-size:13px;font-weight:700;color:var(--gray-500);border-bottom:3px solid transparent;margin-bottom:-1px;transition:all .12s;background:none;border-top:none;border-left:none;border-right:none;cursor:pointer;}
.g-tab:hover{color:var(--navy);}
.g-tab.act{color:var(--teal);border-bottom-color:var(--teal);}

/* ════════════════════════════════════
   ISOMETRIC PATH SYSTEM
════════════════════════════════════ */
.iso-shell{display:flex;height:100%;width:100%;overflow:hidden;}
.iso-left{width:280px;flex-shrink:0;background:linear-gradient(180deg,#0D1545 0%,#001970 60%,#1A3A5E 100%);display:flex;flex-direction:column;align-items:center;position:relative;overflow:hidden;}
.iso-left::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,0.5) 1px,transparent 1px),radial-gradient(circle,rgba(255,255,255,0.2) 1px,transparent 1px);background-size:38px 38px,76px 76px;background-position:0 0,19px 19px;pointer-events:none;}
.iso-panel-top{padding:20px 16px 0;text-align:center;position:relative;z-index:2;width:100%;}
.iso-back-btn{display:flex;align-items:center;gap:6px;font-family:var(--font-head);font-size:11px;font-weight:700;color:rgba(255,255,255,0.5);cursor:pointer;margin-bottom:14px;padding:5px 10px;border-radius:100px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.06);transition:all .15s;width:fit-content;}
.iso-back-btn:hover{color:white;border-color:rgba(255,255,255,0.3);}
.iso-dest-title{font-family:var(--font-head);font-size:15px;font-weight:800;color:white;margin-bottom:4px;}
.iso-dest-sub{font-size:11px;color:rgba(255,255,255,0.4);margin-bottom:16px;}
.iso-path{position:relative;z-index:2;width:100%;padding:8px 20px 20px;flex:1;display:flex;flex-direction:column;justify-content:flex-end;}
.iso-node{display:flex;align-items:center;gap:12px;margin-bottom:4px;cursor:pointer;transition:transform .15s;position:relative;z-index:2;}
.iso-node:hover{transform:translateX(4px);}
.iso-node-icon{width:42px;height:42px;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:18px;border:2px solid rgba(255,255,255,0.15);box-shadow:0 3px 10px rgba(0,0,0,0.3);position:relative;transition:all .2s;}
.iso-node-icon::after{content:'';position:absolute;bottom:-5px;left:50%;transform:translateX(-50%);width:32px;height:7px;background:rgba(0,0,0,0.22);border-radius:50%;filter:blur(3px);}
.iso-node-info{flex:1;min-width:0;}
.iso-node-name{font-family:var(--font-head);font-size:12px;font-weight:700;line-height:1.2;}
.iso-node-desc{font-size:10px;line-height:1.4;margin-top:1px;opacity:.7;}
.iso-node.iso-done .iso-node-icon{background:var(--teal);}
.iso-node.iso-done .iso-node-name{color:rgba(255,255,255,0.9);}
.iso-node.iso-done .iso-node-desc{color:rgba(255,255,255,0.45);}
.iso-node.iso-active .iso-node-icon{background:#F5C518;box-shadow:0 0 0 3px rgba(245,197,24,0.35),0 4px 14px rgba(245,197,24,0.35);}
.iso-node.iso-active .iso-node-name{color:white;}
.iso-node.iso-active .iso-node-desc{color:rgba(255,255,255,0.55);}
.iso-node.iso-lock .iso-node-icon{background:rgba(255,255,255,0.07);}
.iso-node.iso-lock .iso-node-name{color:rgba(255,255,255,0.3);}
.iso-node.iso-lock .iso-node-desc{color:rgba(255,255,255,0.18);}
.iso-node.iso-active .iso-node-icon::before{content:'';position:absolute;inset:-7px;border-radius:17px;border:2px solid rgba(245,197,24,0.45);animation:isoRing 1.8s ease-in-out infinite;}
@keyframes isoRing{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(1.18)}}
.iso-check{position:absolute;top:-5px;right:-5px;width:16px;height:16px;border-radius:50%;background:var(--olive);border:2px solid #0D1545;display:flex;align-items:center;justify-content:center;font-size:8px;color:white;font-weight:800;}
.iso-connector{width:2px;height:18px;margin-left:20px;border-radius:1px;margin-bottom:4px;}
.iso-connector.done{background:var(--teal);}
.iso-connector.active{background:linear-gradient(180deg,var(--teal),#F5C518);}
.iso-connector.upcoming{background:rgba(255,255,255,0.1);}
.iso-right{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--gray-100);}
.iso-topbar{height:54px;flex-shrink:0;background:white;border-bottom:1px solid var(--gray-200);display:flex;align-items:center;padding:0 22px;gap:12px;}
.iso-topbar-title{font-family:var(--font-head);font-size:17px;font-weight:800;color:var(--navy);}
.iso-topbar-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.iso-scroll{flex:1;overflow-y:auto;}
.iso-guide-bar{display:flex;align-items:center;gap:12px;background:var(--navy);padding:12px 20px;margin:16px;border-radius:12px;box-shadow:0 4px 16px rgba(0,25,112,0.2);}
.iso-guide-bar-av{width:36px;height:36px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.iso-guide-bar-nm{font-family:var(--font-head);font-size:10px;font-weight:800;color:rgba(255,255,255,0.45);margin-bottom:2px;}
.iso-guide-bar-msg{font-size:12px;color:white;line-height:1.5;}


/* ════════ DISCOVERY CENTER SUB-APP ════════ */
#dc-app { font-family:'Nunito',sans-serif; width:100%; height:100%; position:relative; overflow:hidden; }
#dc-app * { box-sizing:border-box; }
#dc-app .dc-screen { display:none; width:100%; height:100%; overflow-y:auto; }
#dc-app .dc-screen.dc-active { display:block; }

/* Scene backgrounds */
#dc-app .scene-park {
  background:
    radial-gradient(ellipse 80% 50% at -10% 100%, #3DAA28 0%, transparent 55%),
    radial-gradient(ellipse 70% 45% at 110% 100%, #2D7A1F 0%, transparent 50%),
    linear-gradient(180deg, transparent 55%, #4BB82A 55%, #3DAA28 75%, #2D7A1F 100%),
    linear-gradient(180deg, #87CEEB 0%, #B8E4F5 35%, #D4F0E8 55%, #E8F8D8 65%);
}
#dc-app .scene-library {
  background:
    linear-gradient(180deg, transparent 82%, #C8A060 82%, #B8904A 100%),
    linear-gradient(180deg, #1A5C4A 0%, #1A5C4A 82%);
}

/* DC Header */
#dc-app .dc-header {
  position:sticky; top:0; z-index:20;
  display:flex; align-items:center; justify-content:space-between;
  padding:10px 20px;
  background:rgba(0,25,112,0.94);
  border-bottom:3px solid #F5C842;
}
#dc-app .dc-logo { display:flex; align-items:center; gap:10px; }
#dc-app .dc-logo-mark { font-family:'Fredoka One',cursive; font-size:17px; color:white; }
#dc-app .dc-logo-mark span { color:#F5C842; }
#dc-app .dc-back-btn {
  font-family:'Nunito',sans-serif; font-weight:700; font-size:12px;
  color:rgba(255,255,255,0.75); background:rgba(255,255,255,0.12);
  border:1.5px solid rgba(255,255,255,0.25); border-radius:99px;
  padding:5px 14px; cursor:pointer; transition:all 0.2s;
}
#dc-app .dc-back-btn:hover { background:rgba(255,255,255,0.22); color:white; }
#dc-app .dc-skip-btn {
  font-family:'Nunito',sans-serif; font-weight:700; font-size:12px;
  color:rgba(255,255,255,0.7); background:rgba(255,255,255,0.1);
  border:1.5px solid rgba(255,255,255,0.2); border-radius:99px;
  padding:5px 14px; cursor:pointer; transition:all 0.2s;
}

/* DC Progress */
#dc-app .dc-prog-wrap {
  position:sticky; top:52px; z-index:19;
  background:rgba(0,25,112,0.88);
  padding:6px 20px; display:none; align-items:center; gap:14px;
  border-bottom:2px solid rgba(255,255,255,0.1);
}
#dc-app .dc-prog-wrap.show { display:flex; }
#dc-app .dc-prog-label { font-size:11px; font-weight:800; color:rgba(255,255,255,0.8); min-width:72px; }
#dc-app .dc-prog-track { flex:1; height:12px; background:rgba(255,255,255,0.15); border-radius:99px; overflow:hidden; }
#dc-app .dc-prog-fill {
  height:100%; border-radius:99px;
  background:linear-gradient(90deg,#F5C842,#F4734A);
  transition:width 0.5s cubic-bezier(.34,1.56,.64,1); position:relative;
}
#dc-app .dc-prog-fill::after { content:'⭐'; position:absolute; right:-14px; top:-7px; font-size:16px; animation:dcBounce 1s ease-in-out infinite; }
@keyframes dcBounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
#dc-app .dc-prog-pct { font-size:11px; font-weight:800; color:#F5C842; min-width:32px; text-align:right; }

/* DC scene */
#dc-app .dc-scene-wrap { position:relative; min-height:calc(100vh - 110px); overflow:hidden; }
#dc-app .dc-scene-bg { position:absolute; inset:0; z-index:0; pointer-events:none; overflow:hidden; }
#dc-app .dc-scene-content { position:relative; z-index:5; display:flex; min-height:calc(100vh - 110px); }

/* Avatar stage */
#dc-app .dc-avatar-stage {
  width:300px; flex-shrink:0;
  display:flex; flex-direction:column;
  align-items:center; justify-content:flex-end;
  padding-bottom:0; position:relative; overflow:visible;
}
#dc-app .dc-avatar-speech-wrap {
