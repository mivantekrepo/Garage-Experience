#dc-app .dc-divider { border:none; border-top:2px dashed rgba(0,0,0,0.09); margin:18px 0; }


/* ════════ DISCOVERY CENTER SUB-APP ════════ */
#dc-app { font-family:'Nunito',sans-serif; width:100%; height:100%; position:relative; overflow:hidden; }
