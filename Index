<script>
/* ══ GARAGE v17 — extracted from main prototype ══ */
/* ══ GARAGE v17 ══ */
(function(){

var GSTICKERS = [
  { id:'vault',   em:'🏛', nm:'Vault Explorer',  dc:'Watched 5 videos',         nw:false },
  { id:'profile', em:'⭐', nm:'Profile Star',    dc:'Completed your profile',   nw:true  },
  { id:'assess',  em:'🧭', nm:'Assessment Ace',  dc:'Finished GPS check-in',    nw:true  },
  { id:'squad',   em:'👥', nm:'Squad Goals',     dc:'Added 3 supporters',       nw:true  },
  { id:'key',     em:'🔑', nm:'Key Holder',      dc:'Unlocked The Vault',       nw:false },
  { id:'steps',   em:'🌟', nm:'First Steps',     dc:'Logged in 3 days running', nw:false },
];

var gCurCar  = 0;
var gCurSide = 0;
var gAnim    = false;
var gSel     = null;
var gDrag    = null, gRes = null, gRotH = null;

/* 4 cars x 2 sides sticker layers */
var gLayers = [[null,null],[null,null],[null,null],[null,null]];

function garInitLayers(){
  var sl = document.getElementById('gsticker-layer');
  if(!sl) return;
  sl.innerHTML = '';
  [0,1,2,3].forEach(function(c){
    [0,1].forEach(function(s){
      var d = document.createElement('div');
      d.style.cssText = 'position:absolute;inset:0;display:none;pointer-events:auto;';
      sl.appendChild(d);
      gLayers[c][s] = d;
    });
  });
  gLayers[0][0].style.display = 'block';
}

/* ── Tab switching ── */
window.garTab = function(t){
  ['car','col','tro'].forEach(function(n){
    var tab = document.getElementById('gtab-'+n);
    var panel = document.getElementById('gpanel-'+n);
    if(tab)   tab.classList.toggle('act', n===t);
    if(panel){ panel.classList.toggle('act', n===t); }
  });
  if(t==='col') garRenderCol();
  if(t==='tro') garRenderTro();
};

/* ── Car picker ── */
window.garSelectCar = function(idx){
  if(idx===gCurCar) return;
  garSelectSticker(null);
  document.getElementById('gcar-opt-'+gCurCar).classList.remove('act');
  document.getElementById('gcar-opt-'+idx).classList.add('act');
  gLayers[gCurCar][gCurSide].style.display = 'none';
  gCurCar = idx; gCurSide = 0;
  gLayers[gCurCar][gCurSide].style.display = 'block';
  garUpdatePills();
  var carEl = document.getElementById('gcar-img');
  var imgEl = carEl.querySelector('img');
  carEl.style.opacity = '0';
  setTimeout(function(){
    if(idx === 0){
      var van = document.getElementById('gcar-svg-van');
      var vanImg = van ? van.querySelector('img') : null;
      if(vanImg && imgEl) imgEl.src = vanImg.src;
    } else if(idx === 1) {
      var bottle = document.getElementById('gcar-svg-bottle');
      var bottleImg = bottle ? bottle.querySelector('img') : null;
      if(bottleImg && imgEl) imgEl.src = bottleImg.src;
    } else if(idx === 2) {
      var camper = document.getElementById('gcar-svg-camper');
      var camperImg = camper ? camper.querySelector('img') : null;
      if(camperImg && imgEl) imgEl.src = camperImg.src;
    } else {
      var island = document.getElementById('gcar-svg-island');
      var islandImg = island ? island.querySelector('img') : null;
      if(islandImg && imgEl) imgEl.src = islandImg.src;
    }
    carEl.style.transform = 'none';
    carEl.style.opacity = '1';
  }, 180);
};

/* ── Side nav ── */
window.garSpin = function(dir){ garGoTo((gCurSide+dir+2)%2); };

window.garGoTo = function(next){
  if(gAnim || next===gCurSide) return;
  gAnim = true; garSelectSticker(null);
  var carEl = document.getElementById('gcar-img');
  carEl.style.opacity = '0';
  carEl.style.transform = 'scaleX(0.85)';
  setTimeout(function(){
    gLayers[gCurCar][gCurSide].style.display = 'none';
    gCurSide = next;
    gLayers[gCurCar][gCurSide].style.display = 'block';
    carEl.style.transform = next===1 ? 'scaleX(-1)' : 'none';
    garUpdatePills();
    carEl.style.opacity = '1';
    setTimeout(function(){ gAnim = false; }, 260);
  }, 220);
};

window.garUpdatePills = function(){
  [0,1].forEach(function(i){
    var p = document.getElementById('gpill-'+i);
    if(!p) return;
    p.className = 'gar-side-pill ' + (i===gCurSide ? 'act' : 'inact');
  });
};

/* ── Render sticker shelf ── */
function garRenderShelf(){
  var shelf = document.getElementById('gstk-shelf');
  if(!shelf) return;
  shelf.innerHTML = '';
  GSTICKERS.forEach(function(stk){
    var d = document.createElement('div');
    d.className = 'gar-stk-card';
    d.innerHTML = (stk.nw ? '<div class="gar-stk-new">NEW</div>' : '') +
      '<span class="gar-stk-icon">'+stk.em+'</span>' +
      '<div class="gar-stk-name">'+stk.nm+'</div>' +
      '<div class="gar-stk-desc">'+stk.dc+'</div>';
    d.onclick = function(){ garAddSticker(stk.em); };
    shelf.appendChild(d);
  });
}

/* ── Add sticker ── */
window.garAddSticker = function(emoji){
  var canvas = document.getElementById('gcanvas');
  var layer  = gLayers[gCurCar][gCurSide];
  if(!canvas || !layer) return;
  var sz = 64;
  var cw = canvas.offsetWidth, ch = canvas.offsetHeight;
  var x  = cw*0.2 + Math.random()*cw*0.55 - sz/2;
  var y  = ch*0.15 + Math.random()*ch*0.55 - sz/2;

  var w = document.createElement('div');
  w.className = 'gar-sticker-obj';
  w.style.cssText = 'position:absolute;left:'+x+'px;top:'+y+'px;width:'+sz+'px;height:'+sz+'px;transform:rotate(0deg);cursor:grab;touch-action:none;user-select:none;pointer-events:all;filter:drop-shadow(1px 3px 8px rgba(0,0,0,0.3));';
  w.dataset.angle = '0';
  w.dataset.size  = sz;

  var em = document.createElement('span');
  em.style.cssText = 'display:flex;align-items:center;justify-content:center;width:100%;height:100%;font-size:'+(sz*0.76)+'px;line-height:1;pointer-events:none;';
  em.textContent = emoji;

  var hRot = document.createElement('div');
  hRot.textContent = '↻';
  hRot.style.cssText = 'position:absolute;top:-22px;left:50%;transform:translateX(-50%);width:18px;height:18px;background:#F5C842;border-radius:50%;cursor:grab;border:2px solid white;display:none;align-items:center;justify-content:center;font-size:10px;z-index:20;pointer-events:all;';

  var hDel = document.createElement('div');
  hDel.textContent = '×';
  hDel.style.cssText = 'position:absolute;top:-9px;right:-9px;width:18px;height:18px;background:#EF4444;border-radius:50%;cursor:pointer;border:2px solid white;display:none;align-items:center;justify-content:center;font-size:13px;color:white;font-weight:bold;z-index:20;pointer-events:all;line-height:1;';

  var hRes = document.createElement('div');
  hRes.textContent = '⤡';
  hRes.style.cssText = 'position:absolute;bottom:-9px;right:-9px;width:18px;height:18px;background:#22C55E;border-radius:4px;cursor:nwse-resize;border:2px solid white;display:none;align-items:center;justify-content:center;font-size:9px;color:white;z-index:20;pointer-events:all;';

  hDel.onclick = function(e){ e.stopPropagation(); w.remove(); garSelectSticker(null); };
  hRot.addEventListener('mousedown', garOnRotH);
  hRot.addEventListener('touchstart', garOnRotH, {passive:false});
  hRes.addEventListener('mousedown', garOnResStart);
  hRes.addEventListener('touchstart', garOnResStart, {passive:false});

  w.appendChild(hRot); w.appendChild(hDel); w.appendChild(hRes); w.appendChild(em);
  w.addEventListener('mousedown', garOnDragStart);
  w.addEventListener('touchstart', garOnDragStart, {passive:false});
  w.onclick = function(e){ e.stopPropagation(); garSelectSticker(w); };

  layer.appendChild(w);
  garSelectSticker(w);
};

/* ── Select / deselect ── */
function garSelectSticker(el){
  if(gSel && gSel !== el){
    gSel.style.outline = '';
    gSel.querySelectorAll('div').forEach(function(d){ d.style.display='none'; });
  }
  gSel = el;
  if(el){
    el.style.outline = '2px dashed #7A853B';
    el.style.outlineOffset = '3px';
    el.querySelectorAll('div').forEach(function(d){ d.style.display='flex'; });
  }
}

var canvas = document.getElementById('gcanvas');
if(canvas){
  canvas.addEventListener('click', function(e){
    if(!e.target.closest('.gar-sticker-obj')) garSelectSticker(null);
  });
}

/* ── Drag ── */
function garOnDragStart(e){
  if(e.target.style.cursor==='nwse-resize') return;
  e.preventDefault(); e.stopPropagation();
  var el = e.currentTarget; garSelectSticker(el);
  var t = e.touches ? e.touches[0] : e;
  var r = document.getElementById('gcanvas').getBoundingClientRect();
  gDrag = {el:el, ox:t.clientX-r.left-parseFloat(el.style.left), oy:t.clientY-r.top-parseFloat(el.style.top)};
  el.style.cursor = 'grabbing';
  function move(ev){
    if(!gDrag) return;
    var tt = ev.touches?ev.touches[0]:ev;
    var rr = document.getElementById('gcanvas').getBoundingClientRect();
    var nx = Math.max(0, Math.min(rr.width-el.offsetWidth,   tt.clientX-rr.left-gDrag.ox));
    var ny = Math.max(0, Math.min(rr.height-el.offsetHeight, tt.clientY-rr.top-gDrag.oy));
    el.style.left = nx+'px'; el.style.top = ny+'px';
  }
  function up(){ if(gDrag) gDrag.el.style.cursor='grab'; gDrag=null; off(move,up); }
  on(move,up);
}

/* ── Resize ── */
function garOnResStart(e){
  e.preventDefault(); e.stopPropagation();
  var el = e.currentTarget.parentElement;
  var t = e.touches?e.touches[0]:e;
  var r = el.getBoundingClientRect();
  var startD = Math.hypot(t.clientX-(r.left+r.width/2), t.clientY-(r.top+r.height/2));
  gRes = {el:el, startD:startD, base:parseFloat(el.dataset.size)||64};
  function move(ev){
    if(!gRes) return;
    var tt = ev.touches?ev.touches[0]:ev;
    var rr = gRes.el.getBoundingClientRect();
    var d  = Math.hypot(tt.clientX-(rr.left+rr.width/2), tt.clientY-(rr.top+rr.height/2));
    var sz = Math.max(28, Math.min(160, gRes.base*(d/gRes.startD)));
    gRes.el.dataset.size = sz;
    gRes.el.style.width  = sz+'px';
    gRes.el.style.height = sz+'px';
    var sp = gRes.el.querySelector('span');
    if(sp) sp.style.fontSize = (sz*0.76)+'px';
  }
  function up(){ gRes=null; off(move,up); }
  on(move,up);
}

/* ── Rotate ── */
function garOnRotH(e){
  e.preventDefault(); e.stopPropagation();
  var el = e.currentTarget.parentElement;
  var t  = e.touches?e.touches[0]:e;
  var r  = el.getBoundingClientRect();
  gRotH = {el:el, sa:Math.atan2(t.clientY-(r.top+r.height/2), t.clientX-(r.left+r.width/2))*180/Math.PI, ba:parseFloat(el.dataset.angle)||0};
  function move(ev){
    if(!gRotH) return;
    var tt = ev.touches?ev.touches[0]:ev;
    var rr = gRotH.el.getBoundingClientRect();
    var a  = Math.atan2(tt.clientY-(rr.top+rr.height/2), tt.clientX-(rr.left+rr.width/2))*180/Math.PI;
    var na = gRotH.ba + (a-gRotH.sa);
    na = ((na%360)+360)%360; if(na>180) na-=360;
    gRotH.el.dataset.angle = na;
    gRotH.el.style.transform = 'rotate('+na+'deg)';
  }
  function up(){ gRotH=null; off(move,up); }
  on(move,up);
}

/* ── All Stickers tab ── */
function garRenderCol(){
  var el = document.getElementById('gcol-grid');
  if(!el) return;
