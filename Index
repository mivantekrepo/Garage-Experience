  GSTICKERS.forEach(function(stk){
    var d = document.createElement('div');
    d.className = 'gar-all-card';
    d.innerHTML = (stk.nw?'<div class="gar-stk-new">NEW</div>':'')+
      '<span class="gar-stk-icon">'+stk.em+'</span>'+
      '<div class="gar-stk-name">'+stk.nm+'</div>'+
      '<div class="gar-stk-desc">'+stk.dc+'</div>';
    d.onclick = function(){ garTab('car'); garAddSticker(stk.em); };
    el.appendChild(d);
  });
}

/* ── Trophies tab ── */
function garRenderTro(){
  var el = document.getElementById('gtro-grid');
  if(!el) return;
  var data = [
    {em:'🏛', nm:'Vault Explorer',  dc:'Watched 5 videos',          ok:true,  lk:false},
    {em:'⭐', nm:'Profile Star',    dc:'Completed your profile',    ok:false, lk:false},
    {em:'🧭', nm:'Assessment Ace',  dc:'Finished GPS check-in',     ok:false, lk:false},
    {em:'👥', nm:'Squad Goals',     dc:'Added 3 supporters',        ok:false, lk:false},
    {em:'🔑', nm:'Key Holder',      dc:'Unlocked The Vault',        ok:false, lk:false},
    {em:'🌟', nm:'First Steps',     dc:'3 login days in a row',     ok:false, lk:false},
    {em:'🗺', nm:'Map Master',      dc:'Visit all 5 destinations',  ok:false, lk:true },
    {em:'🏆', nm:'Path Complete',   dc:'Finish your full profile',  ok:false, lk:true },
  ];
  el.innerHTML = '';
  data.forEach(function(t){
    var d = document.createElement('div');
    d.className = 'gar-tro-card' + (t.ok?' earned':'') + (t.lk?' locked':'');
    var badge = t.lk ? '<span class="gar-tro-badge locked">🔒 Locked</span>'
               : t.ok ? '<span class="gar-tro-badge earned">✓ Earned</span>'
               : '<span class="gar-tro-badge notyet">Not yet</span>';
    d.innerHTML = '<div style="font-size:36px;margin-bottom:8px;">'+t.em+'</div>'+
      '<div style="font-family:\'Poppins\',sans-serif;font-size:13px;font-weight:800;color:#001970;">'+t.nm+'</div>'+
      '<div style="font-size:12px;color:#6B7280;margin-top:4px;line-height:1.5;">'+t.dc+'</div>'+
      badge;
    el.appendChild(d);
  });
}

/* ── Clear ── */
window.garClearSide = function(){
  if(gLayers[gCurCar][gCurSide])
    gLayers[gCurCar][gCurSide].querySelectorAll('.gar-sticker-obj').forEach(function(e){e.remove();});
  garSelectSticker(null);
};
window.garClearAll = function(){
  gLayers.forEach(function(car){ car.forEach(function(side){
    side.querySelectorAll('.gar-sticker-obj').forEach(function(e){e.remove();});
  }); });
  garSelectSticker(null);
};

/* ── Helpers ── */
function on(m,u){
  document.addEventListener('mousemove',m);
  document.addEventListener('mouseup',u);
  document.addEventListener('touchmove',m,{passive:false});
  document.addEventListener('touchend',u);
}
function off(m,u){
  document.removeEventListener('mousemove',m);
  document.removeEventListener('mouseup',u);
  document.removeEventListener('touchmove',m);
  document.removeEventListener('touchend',u);
}

/* ── Init ── */
window.garInit = function(){
  garInitLayers();
  garRenderShelf();
  garUpdatePills();
  // Load default car image (Sticker Van)
  var defaultImg = document.querySelector('#gcar-img img');
  var van = document.getElementById('gcar-svg-van');
  var vanImg = van ? van.querySelector('img') : null;
  if(defaultImg && vanImg) defaultImg.src = vanImg.src;
  var b = document.getElementById('home-bdg');  if(b)  b.style.display='none';
  var b2= document.getElementById('gar-bdg');   if(b2) b2.style.display='none';
  var ma= document.getElementById('map-alert'); if(ma) ma.style.display='none';
};

})();
</script>

<script>
/* Auto-init the Garage on load */
document.addEventListener('DOMContentLoaded', function(){
  if(typeof window.garInit === 'function'){
    window.garInit();
  }
});
</script>

