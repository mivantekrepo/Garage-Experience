#dc-app .dc-tf-card { background:rgba(255,255,255,0.96); border-radius:12px; border:2px solid rgba(255,255,255,0.8); padding:11px; margin-bottom:7px; box-shadow:0 2px 8px rgba(0,0,0,0.05); }
